#!/usr/bin/env zsh
# Issue Agent CLI — local GitHub issue resolver
source "$HOME/.config/cockpit/secrets.env" 2>/dev/null
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"
export ISSUE_AGENT_ROOT="${ISSUE_AGENT_ROOT:-$HOME/issue-agent}"
export ISSUE_AGENT_AIDER="${ISSUE_AGENT_AIDER:-$HOME/.local/venvs/aider/bin/aider}"
export OLLAMA_HOST="${OLLAMA_HOST:-http://127.0.0.1:11434}"
export OLLAMA_API_BASE="${OLLAMA_API_BASE:-$OLLAMA_HOST}"
exec "${ISSUE_AGENT_AIDER%/*}/python" "$ISSUE_AGENT_ROOT/issue_agent.py" "$@"