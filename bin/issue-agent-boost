#!/usr/bin/env zsh
# Polish all repos + run local agent on agent-triage issues
source "$HOME/.config/cockpit/secrets.env" 2>/dev/null
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"
export OLLAMA_HOST="${OLLAMA_HOST:-http://127.0.0.1:11434}"
export OLLAMA_API_BASE="${OLLAMA_API_BASE:-$OLLAMA_HOST}"
exec "$HOME/.local/venvs/aider/bin/python" "$HOME/issue-agent/issue_agent.py" boost --max 2 "$@"